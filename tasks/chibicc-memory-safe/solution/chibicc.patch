+static bool pointer_initializer_bounds(Node *node, long *lower, size_t *size) {
+  switch (node->kind) {
+  case ND_CAST:
+    return pointer_initializer_bounds(node->lhs, lower, size);
+  case ND_ADD:
+  case ND_SUB:
+    return pointer_initializer_bounds(node->lhs, lower, size);
+  case ND_VAR:
+    if (node->var->ty->kind != TY_ARRAY)
+      return false;
+    *lower = 0;
+    *size = node->var->ty->size;
+    return true;
+  case ND_ADDR:
+    if (node->lhs->kind == ND_VAR) {
+      *lower = 0;
+      *size = node->lhs->var->ty->size;
+      return true;
+    }
+    return pointer_initializer_bounds(node->lhs, lower, size);
+  case ND_DEREF:
+    return pointer_initializer_bounds(node->lhs, lower, size);
+  case ND_MEMBER:
+    if (node->lhs->kind == ND_VAR) {
+      *lower = 0;
+      *size = node->lhs->var->ty->size;
+    } else if (!pointer_initializer_bounds(node->lhs, lower, size)) {
+        return false;
+    }
+    *lower += node->member->offset;
+    *size = node->member->ty->size;
+    return true;
+  default:
+    return false;
+  }
+}
